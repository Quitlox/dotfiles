.shell powershell

# +- Reload / WM Control ----------------------------------+
win + shift + o         : komorebic reload-configuration; taskkill /f /im whkd.exe; Start-Process whkd -WindowStyle hidden
win + shift + r         : komorebic retile
win + p                 : komorebic toggle-pause
win + i                 : komorebic toggle-shortcuts

# Reload whkd
alt + shift + o         : taskkill /f /im whkd.exe; Start-Process whkd -WindowStyle hidden

# Quit komorebi + whkd
win + shift + q         : komorebic stop --whkd --bar

# +- Applications -----------------------------------------+
win + return            : alacritty
win + shift + return    : wt.exe
win + shift + w         : komorebic close
win + m                 : komorebic minimize

# App launchers (win + alt)
win + alt + e           : explorer.exe
win + alt + c           : Start-Process "C:\Program Files\Google\Chrome\Application\chrome.exe" -ArgumentList '--profile-directory="Profile 1"'
win + alt + b           : start msedge
win + alt + n           : neovide
win + alt + o           : Start-Process "C:\Program Files\Microsoft Office\root\Office16\OUTLOOK.EXE"
win + alt + t           : start msteams:

# App launcher: PowerToys Command Palette (via internal named event)
win + d                 : powershell -NoProfile -NonInteractive -WindowStyle Hidden -Command "[System.Threading.EventWaitHandle]::OpenExisting('Local\PowerToysCmdPal-ShowEvent-62336fcd-8611-4023-9b30-091a6af4cc5a').Set()"

# +- Focus (vim-style) ------------------------------------+
win + h                 : komorebic focus left
win + j                 : komorebic focus down
win + k                 : komorebic focus up
# NOTE: win + l requires DisableLockWorkstation=1 in registry:
# HKCU\Software\Microsoft\Windows\CurrentVersion\Policies\System
# To lock the screen, use win + alt + l (see Lock Screen section below).
win + l                 : komorebic focus right
win + space             : komorebic cycle-focus next
win + oem_4             : komorebic cycle-focus previous # [
win + oem_6             : komorebic cycle-focus next     # ]

# +- Move Windows -----------------------------------------+
win + shift + h         : komorebic move left
win + shift + j         : komorebic move down
win + shift + k         : komorebic move up
win + shift + l         : komorebic move right
win + shift + space     : komorebic promote

# +- Resize -----------------------------------------------+
# No submap support in whkd, so use win+ctrl combos
# (matches Hyprland resize mode directions but always active)
win + ctrl + h          : komorebic resize-axis horizontal decrease
win + ctrl + l          : komorebic resize-axis horizontal increase
win + ctrl + k          : komorebic resize-axis vertical decrease
win + ctrl + j          : komorebic resize-axis vertical increase

# +- Stacking (i3 tabbed containers) ---------------------+
win + s                 : komorebic stack left
win + shift + s         : komorebic unstack
win + left              : komorebic stack left
win + down              : komorebic stack down
win + up                : komorebic stack up
win + right             : komorebic stack right
win + oem_comma         : komorebic cycle-stack previous  # ,
win + oem_1             : komorebic cycle-stack next      # ;
win + shift + oem_4     : komorebic cycle-stack previous  # [
win + shift + oem_6     : komorebic cycle-stack next      # ]

# +- Window Toggles --------------------------------------+
win + f                 : komorebic toggle-monocle
win + shift + f         : komorebic toggle-float
ctrl + shift + space    : komorebic toggle-float

# +- Layouts (BSP split direction) ------------------------+
# BSP auto-splits; flip-layout changes the tree orientation
win + v                 : komorebic flip-layout vertical
win + b                 : komorebic flip-layout horizontal
win + e                 : komorebic cycle-layout next
win + shift + e         : komorebic cycle-layout previous

# +- Workspaces: Switch (1-9) ----------------------------+
win + 1                 : komorebic focus-named-workspace 1
win + 2                 : komorebic focus-named-workspace 2
win + 3                 : komorebic focus-named-workspace 3
win + 4                 : komorebic focus-named-workspace 4
win + 5                 : komorebic focus-named-workspace 5
win + 6                 : komorebic focus-named-workspace 6
win + 7                 : komorebic focus-named-workspace 7
win + 8                 : komorebic focus-named-workspace 8
win + 9                 : komorebic focus-named-workspace 9
# Workspace back-and-forth (toggle to last active)
win + 0                 : komorebic focus-last-workspace

# +- Workspaces: Move Window (1-9) -----------------------+
win + shift + 1         : komorebic move-to-named-workspace 1
win + shift + 2         : komorebic move-to-named-workspace 2
win + shift + 3         : komorebic move-to-named-workspace 3
win + shift + 4         : komorebic move-to-named-workspace 4
win + shift + 5         : komorebic move-to-named-workspace 5
win + shift + 6         : komorebic move-to-named-workspace 6
win + shift + 7         : komorebic move-to-named-workspace 7
win + shift + 8         : komorebic move-to-named-workspace 8
win + shift + 9         : komorebic move-to-named-workspace 9

# +- Lock Screen ------------------------------------------+
# Lock_And_Leave.cmd flips DisableLockWorkstation back to 0 (rundll32
# LockWorkStation is blocked while it is 1), then locks. The
# "ReDisableLockOnUnlock" scheduled task sets it back to 1 on unlock.
win + alt + l           : & "C:\Users\witloxkhd\OneDrive - TNO\Documents\Files\Hacks\Windows Automated Changes\Lock_And_Leave.cmd"

# +- Multi-Monitor ----------------------------------------+
win + ctrl + oem_4      : komorebic cycle-monitor previous # [
win + ctrl + oem_6      : komorebic cycle-monitor next     # ]
win + ctrl + shift + h  : komorebic move-to-monitor 0
win + ctrl + shift + l  : komorebic move-to-monitor 1
