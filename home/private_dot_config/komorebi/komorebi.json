{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.40/schema.json",
  "app_specific_configuration_path": "$Env:KOMOREBI_CONFIG_HOME/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "cross_boundary_behaviour": "Monitor",
  "window_container_behaviour": "Create",
  "default_workspace_padding": 2,
  "default_container_padding": 2,
  "border": true,
  "border_width": 4,
  "border_offset": -1,
  "border_style": "System",
  "border_implementation": "Komorebi",
  "animation": {
    "enabled": true,
    "fps": 60,
    "duration": 250,
    "style": "EaseOutCubic"
  },
  "mouse_follows_focus": false,
  "resize_delta": 100,
  "toggle_float_placement": "CenterAndResize",
  "stackbar": {
    "mode": "OnStack",
    "label": "Title",
    "height": 24,
    "tabs": {
      "font_family": "JetBrains Mono"
    }
  },
  "floating_applications": [
    {
      "kind": "Title",
      "id": "Picture-in-Picture",
      "matching_strategy": "Contains"
    },
    {
      "kind": "Exe",
      "id": "blueman-manager",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "OUTLOOK.EXE",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "ms-teams.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "M365Copilot.exe",
      "matching_strategy": "Equals"
    },
    [
      {
        "kind": "Exe",
        "id": "chrome.exe",
        "matching_strategy": "Equals"
      },
      {
        "kind": "Title",
        "id": "Bitwarden",
        "matching_strategy": "Equals"
      }
    ],
    [
      {
        "kind": "Exe",
        "id": "msedge.exe",
        "matching_strategy": "Equals"
      },
      {
        "kind": "Title",
        "id": "Bitwarden",
        "matching_strategy": "Equals"
      }
    ]
  ],
  "monitors": [
    {
      "workspaces": [
        { "name": "1", "layout": "Columns", "initial_workspace_rules": [
          { "kind": "Exe", "id": "OUTLOOK.EXE", "matching_strategy": "Equals" },
          { "kind": "Exe", "id": "ms-teams.exe", "matching_strategy": "Equals" }
        ] },
        { "name": "2", "layout": "Columns" },
        { "name": "3", "layout": "Columns" },
        { "name": "4", "layout": "Columns" },
        { "name": "5", "layout": "Columns" },
        { "name": "6", "layout": "Columns" },
        { "name": "7", "layout": "Columns" },
        { "name": "8", "layout": "Columns" },
        { "name": "9", "layout": "Columns" }
      ]
    }
  ]
}
